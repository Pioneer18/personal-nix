#!/usr/bin/env bash
# Generated by /tachikoma. Lives at .tachikoma/tachikoma.sh in the project repo.
# Edit at your own risk — re-running /tachikoma will overwrite.

set -e
set -o pipefail

REPO="{{REPO_PATH}}"
SENTINEL='{{SENTINEL}}'
ALLOWED_TOOLS='{{ALLOWED_TOOLS}}'
PROMPT_FILE="$REPO/.tachikoma/prompt.md"
PROGRESS_FILE="$REPO/.tachikoma/progress.txt"
LOG_FILE="$REPO/.tachikoma/run.log"
PID_FILE="$REPO/.tachikoma/run.pid"
OUTCOME_FILE="$REPO/.tachikoma/outcome"

usage() {
  cat <<EOF
Usage: tachikoma.sh --once
       tachikoma.sh --afk N
EOF
  exit 1
}

[ $# -ge 1 ] || usage

MODE="$1"
case "$MODE" in
  --once) MAX_ITER=1 ;;
  --afk)
    [ $# -ge 2 ] || usage
    MAX_ITER="$2"
    case "$MAX_ITER" in (*[!0-9]*|"") echo "afk N must be a positive integer" >&2; exit 1 ;; esac
    [ "$MAX_ITER" -le 50 ] || { echo "afk cap exceeds hard ceiling 50" >&2; exit 1; }
    ;;
  *) usage ;;
esac

cd "$REPO"

# Lockfile: refuse if a live tachikoma is already running here.
if [ -f "$PID_FILE" ]; then
  EXISTING_PID="$(cat "$PID_FILE" 2>/dev/null || echo "")"
  if [ -n "$EXISTING_PID" ] && kill -0 "$EXISTING_PID" 2>/dev/null; then
    echo "tachikoma already running (pid $EXISTING_PID). Use /tachikoma stop or kill $EXISTING_PID." >&2
    exit 1
  fi
  rm -f "$PID_FILE"
fi
echo $$ > "$PID_FILE"

# Self-heal base_branch metadata if Phase 3 scaffold missed it. tachikoma_status
# and the merge tooling both read this file; missing it makes worktree merges
# target the wrong branch.
BASE_BRANCH_FILE="$REPO/.tachikoma/base_branch"
if [ ! -f "$BASE_BRANCH_FILE" ]; then
  git rev-parse --abbrev-ref HEAD > "$BASE_BRANCH_FILE"
fi

# Initialise progress file if absent.
[ -f "$PROGRESS_FILE" ] || : > "$PROGRESS_FILE"

OUTCOME="unknown"
ITER=0

cleanup() {
  # Order matters: rm PID first so tachikoma_status sees the run as done,
  # then write outcome so observers reading after PID-clear see the final
  # state, then notify (which may block briefly on osascript).
  rm -f "$PID_FILE"
  echo "$OUTCOME" > "$OUTCOME_FILE"
  notify "$OUTCOME" "$ITER"
}

stop_handler() {
  OUTCOME="stopped"
  {
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    echo "  ⏹ STOPPED — received signal at iter $ITER"
    echo "  Run /tachikoma resume to continue, or /tachikoma done to review."
    echo "═══════════════════════════════════════════════════════════════"
    echo ""
  } | tee -a "$LOG_FILE" >&2
  trap - TERM
  cleanup
  printf '\a' >&2 || true
  exit 130
}

notify() {
  local outcome="$1"
  local iters="$2"
  local title="Tachikoma $outcome"
  local body="repo: $(basename "$REPO") · iters: $iters/$MAX_ITER · branch: $(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")"
  # Fire-and-forget: detach osascript in a subshell so a stalled notification
  # daemon can't keep this process alive after the EXIT trap runs.
  if command -v osascript >/dev/null 2>&1; then
    ( osascript -e "display notification \"$body\" with title \"$title\"" >/dev/null 2>&1 & ) || true
  fi
  printf '\a' >&2 || true
  echo "[tachikoma] $outcome — $body" | tee -a "$LOG_FILE" >&2
}

trap cleanup EXIT
trap stop_handler TERM INT

# Refuse to run on a "main" branch even if the skill missed it.
BRANCH="$(git rev-parse --abbrev-ref HEAD)"
case "$BRANCH" in
  main|master|develop|production)
    echo "[tachikoma] refusing to run on protected branch $BRANCH" >&2
    OUTCOME="error"
    exit 1
    ;;
esac

{
  echo ""
  echo "═══════════════════════════════════════════════════════════════"
  echo "  🚀 starting — repo: $(basename "$REPO") · branch: $BRANCH"
  echo "  cap: $MAX_ITER iter(s) · pid: $$"
  echo "═══════════════════════════════════════════════════════════════"
  echo ""
} | tee "$LOG_FILE"

for ((ITER=1; ITER<=MAX_ITER; ITER++)); do
  echo "─── iter $ITER / $MAX_ITER ─────────────────────────────────────" | tee -a "$LOG_FILE"

  # Bail if working tree is dirty at iteration start — previous iteration
  # left something half-done. `git status --porcelain` is unborn-HEAD safe.
  if [ -n "$(git status --porcelain)" ]; then
    echo "[tachikoma] working tree dirty at start of iter $ITER. Bailing — manual cleanup required." | tee -a "$LOG_FILE" >&2
    OUTCOME="error"
    exit 1
  fi

  # Single iteration. Stream output to both stdout and the log.
  # Note: --print/-p makes claude headless. --allowed-tools narrows blast radius.
  set +e
  RESULT="$(claude -p "$(cat "$PROMPT_FILE")" \
              --allowed-tools "$ALLOWED_TOOLS" \
              --add-dir "$REPO" \
              2>&1 | tee -a "$LOG_FILE")"
  RC=$?
  set -e

  if [ $RC -ne 0 ]; then
    {
      echo ""
      echo "═══════════════════════════════════════════════════════════════"
      echo "  ❌ ERROR — claude exited with code $RC at iter $ITER"
      echo "  Run /tachikoma resume to retry, or /tachikoma done to review."
      echo "═══════════════════════════════════════════════════════════════"
      echo ""
    } | tee -a "$LOG_FILE" >&2
    OUTCOME="error"
    exit $RC
  fi

  if [[ "$RESULT" == *"$SENTINEL"* ]]; then
    {
      echo ""
      echo "═══════════════════════════════════════════════════════════════"
      echo "  🏁 TACHIKOMA COMPLETE"
      echo "  $ITER iteration(s) · branch: $(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")"
      echo "  Run /tachikoma done to review and merge."
      echo "═══════════════════════════════════════════════════════════════"
      echo ""
    } | tee -a "$LOG_FILE"
    OUTCOME="complete"
    exit 0
  fi

  LAST_LINE="$(tail -n 1 "$PROGRESS_FILE" 2>/dev/null || true)"
  {
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    echo "  ✓ MILESTONE — iter $ITER / $MAX_ITER"
    echo "  ${LAST_LINE:-(progress.txt empty)}"
    echo "═══════════════════════════════════════════════════════════════"
    echo ""
  } | tee -a "$LOG_FILE"
done

{
  echo ""
  echo "═══════════════════════════════════════════════════════════════"
  echo "  ⏱ CAP HIT — $MAX_ITER iterations without sentinel"
  echo "  Run /tachikoma resume to continue, or /tachikoma done to review what's committed."
  echo "═══════════════════════════════════════════════════════════════"
  echo ""
} | tee -a "$LOG_FILE"
OUTCOME="cap"
exit 0
