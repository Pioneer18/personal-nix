#!/usr/bin/env bash
# Generated by /tachikoma. Lives at .tachikoma/tachikoma.sh in the project repo.
# Edit at your own risk — re-running /tachikoma will overwrite.

set -e
set -o pipefail

REPO="{{REPO_PATH}}"
SENTINEL='{{SENTINEL}}'
ALLOWED_TOOLS='{{ALLOWED_TOOLS}}'
# ADR 008 P3 — explicit model selection per phase (no silent CLI default).
MODEL='{{MODEL}}'
PLANNER_MODEL='{{PLANNER_MODEL}}'
# ADR 008 P1 — verifier-gate inputs.
BASE_BRANCH_VAL='{{BASE_BRANCH}}'
TYPECHECK_CMD='{{TYPECHECK_CMD}}'
TEST_CMD='{{TEST_CMD}}'
LINT_CMD='{{LINT_CMD}}'
# ADR 008 P5 — compaction cadence (call lib/progress-summary.sh every N iters).
COMPACTION_INTERVAL='{{COMPACTION_INTERVAL}}'
# Skill install dir — for lib scripts (verifier-gate, repo-map, progress-summary).
LIB_DIR='{{LIB_DIR}}'
PROMPT_FILE="$REPO/.tachikoma/prompt.md"
PROGRESS_FILE="$REPO/.tachikoma/progress.txt"
PROGRESS_SUMMARY_FILE="$REPO/.tachikoma/progress.summary.md"
LOG_FILE="$REPO/.tachikoma/run.log"
PID_FILE="$REPO/.tachikoma/run.pid"
OUTCOME_FILE="$REPO/.tachikoma/outcome"
SHIP_PROMPT_FILE="$REPO/.tachikoma/ship.md"
SHIP_LOG_FILE="$REPO/.tachikoma/ship.log"
ITER_TMP="$REPO/.tachikoma/.iter.tmp"

usage() {
  cat <<EOF
Usage: tachikoma.sh [--dev] --once
       tachikoma.sh [--dev] --afk N

  --once      Run one iteration then stop.
  --afk N     Run up to N iterations (max 50).
  --dev       Dev mode: stream all claude output to the terminal.
              Default (light mode): only structured progress banners are shown.
EOF
  exit 1
}

VERBOSE=0
MODE=""
MAX_ITER=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dev)  VERBOSE=1; shift ;;
    --once) MODE="once"; MAX_ITER=1; shift ;;
    --afk)
      MODE="afk"
      [[ "${2:-}" =~ ^[0-9]+$ ]] || { echo "afk N must be a positive integer" >&2; exit 1; }
      MAX_ITER="$2"
      [ "$MAX_ITER" -le 50 ] || { echo "afk cap exceeds hard ceiling 50" >&2; exit 1; }
      shift 2
      ;;
    *) usage ;;
  esac
done

[[ -n "$MODE" ]] || usage

cd "$REPO"

# Symbol set — fall back to ASCII if locale isn't UTF-8.
if [[ "${LANG:-}${LC_ALL:-}${LC_CTYPE:-}" == *[Uu][Tt][Ff]-8* ]]; then
  SYM_START="🚀" SYM_OK="✓" SYM_ERR="❌" SYM_STOP="⏹" SYM_DONE="🏁" SYM_CAP="⏱" SYM_WARN="⚠"
  RULE_MAIN="═══════════════════════════════════════════════════════════════"
  RULE_ITER="─── iter"
  RULE_SHIP="─── auto-ship"
else
  SYM_START="[start]" SYM_OK="[ok]" SYM_ERR="[err]" SYM_STOP="[stop]" SYM_DONE="[done]" SYM_CAP="[cap]" SYM_WARN="[warn]"
  RULE_MAIN="==============================================================="
  RULE_ITER="--- iter"
  RULE_SHIP="--- auto-ship"
fi

# Lockfile: refuse if a live tachikoma is already running here.
if [ -f "$PID_FILE" ]; then
  EXISTING_PID="$(cat "$PID_FILE" 2>/dev/null || echo "")"
  if [ -n "$EXISTING_PID" ] && kill -0 "$EXISTING_PID" 2>/dev/null; then
    echo "tachikoma already running (pid $EXISTING_PID). Use /tachikoma stop or kill $EXISTING_PID." >&2
    exit 1
  fi
  rm -f "$PID_FILE"
fi
echo $$ > "$PID_FILE"

# Self-heal base_branch metadata if Phase 3 scaffold missed it.
BASE_BRANCH_FILE="$REPO/.tachikoma/base_branch"
if [ ! -f "$BASE_BRANCH_FILE" ]; then
  git rev-parse --abbrev-ref HEAD > "$BASE_BRANCH_FILE"
fi
# BASE_BRANCH for verifier-gate diff scan — prefer scaffold-time value,
# fall back to file (self-heal path).
BASE_BRANCH="${BASE_BRANCH_VAL:-$(cat "$BASE_BRANCH_FILE")}"

# Initialise progress file if absent.
[ -f "$PROGRESS_FILE" ] || : > "$PROGRESS_FILE"

OUTCOME="unknown"
ITER=0

cleanup() {
  rm -f "$PID_FILE" "$ITER_TMP"
  echo "$OUTCOME" > "$OUTCOME_FILE"
  notify "$OUTCOME" "$ITER"
}

stop_handler() {
  OUTCOME="stopped"
  {
    echo ""
    echo "$RULE_MAIN"
    echo "  $SYM_STOP STOPPED — received signal at iter $ITER"
    echo "  Run /tachikoma resume to continue, or /tachikoma done to ship what's committed."
    echo "$RULE_MAIN"
    echo ""
  } | tee -a "$LOG_FILE" >&2
  trap - TERM
  cleanup
  printf '\a' >&2 || true
  exit 130
}

notify() {
  local outcome="$1"
  local iters="$2"
  local title="Tachikoma $outcome"
  local body="repo: $(basename "$REPO") · iters: $iters/$MAX_ITER · branch: $(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")"
  if command -v osascript >/dev/null 2>&1; then
    ( osascript -e "display notification \"$body\" with title \"$title\"" >/dev/null 2>&1 & ) || true
  fi
  printf '\a' >&2 || true
  echo "[tachikoma] $outcome — $body" | tee -a "$LOG_FILE" >&2
}

# run_claude <prompt_file> <log_file> [extra_tools]
# Runs claude -p --output-format json. Extracts result text for log (readable).
# Accumulates token usage to ~/.tachikoma/usage_stats.json for SwiftBar display.
# ITER_TMP retains full JSON so sentinel detection still works (sentinel is a
# literal substring of the JSON result field — no escaping needed).
#
# API auth routing:
#   Default — unsets ANTHROPIC_API_KEY so claude -p falls back to personal Max
#             subscription (claude.ai OAuth). Keeps tachikoma usage off company quota.
#   Override — set TACHIKOMA_USE_COMPANY_API=1 before launching tachikoma.sh to
#             force the company API key (e.g. for RelyMD email processing tasks).
run_claude() {
  local prompt_file="$1"
  local log_file="$2"
  local tools="${3:-$ALLOWED_TOOLS}"
  # ADR 008 P3 — explicit per-phase model. Caller can pass $4 to override
  # (e.g. ship uses the executor MODEL; planner/evaluator use PLANNER_MODEL).
  local model="${4:-$MODEL}"

  if [[ -n "${TACHIKOMA_USE_COMPANY_API:-}" ]]; then
    CLAUDE_ENV_ARGS=()
  else
    CLAUDE_ENV_ARGS=(env -u ANTHROPIC_API_KEY)
  fi

  # --model omitted if blank (fresh installs pre-conf-migration). Surface a
  # one-shot warning so the smell is visible.
  local model_args=()
  if [[ -n "$model" ]]; then
    model_args=(--model "$model")
  else
    echo "[tachikoma] WARN — no model set; falling back to claude CLI default. Add 'model = sonnet' to ~/.claude/tachikoma.conf." >&2
  fi

  set +e
  "${CLAUDE_ENV_ARGS[@]}" claude -p "$(cat "$prompt_file")" \
    "${model_args[@]}" \
    --output-format json \
    --allowed-tools "$tools" \
    --add-dir "$REPO" \
    --dangerously-skip-permissions \
    2>> "$log_file" > "$ITER_TMP"
  CLAUDE_RC=$?
  set -e

  # Extract readable result → log + terminal (verbose); accumulate token counts.
  # Falls back to raw ITER_TMP content if JSON parsing fails.
  python3 - "$ITER_TMP" "$log_file" "$HOME/.tachikoma/usage_stats.json" "$VERBOSE" <<'PYEOF' 2>/dev/null \
    || cat "$ITER_TMP" >> "$log_file"
import json, sys, os
from datetime import datetime

iter_file, log_file, stats_file, verbose = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
try:
    with open(iter_file) as f:
        d = json.load(f)
    result = d.get('result', '')
    with open(log_file, 'a') as f:
        f.write(result + '\n')
    if verbose == '1':
        print(result, flush=True)
    usage = d.get('usage') or {}
    inp = int(usage.get('input_tokens') or 0)
    out = int(usage.get('output_tokens') or 0)
    s = {}
    if os.path.exists(stats_file):
        try:
            with open(stats_file) as f: s = json.load(f)
        except: pass
    today = datetime.now().strftime('%Y-%m-%d')
    if s.get('today_date') != today:
        s.update({'today_date': today, 'today_input': 0, 'today_output': 0, 'today_calls': 0})
    s['today_input'] = s.get('today_input', 0) + inp
    s['today_output'] = s.get('today_output', 0) + out
    s['today_calls'] = s.get('today_calls', 0) + 1
    s['total_input'] = s.get('total_input', 0) + inp
    s['total_output'] = s.get('total_output', 0) + out
    s['total_calls'] = s.get('total_calls', 0) + 1
    s['last_updated'] = datetime.now().isoformat()
    os.makedirs(os.path.dirname(stats_file), exist_ok=True)
    tmp = stats_file + '.tmp'
    with open(tmp, 'w') as f: json.dump(s, f)
    os.rename(tmp, stats_file)
except:
    try:
        with open(iter_file) as f: raw = f.read()
        with open(log_file, 'a') as f: f.write(raw + '\n')
        if verbose == '1': print(raw, flush=True)
    except: pass
PYEOF
}

trap cleanup EXIT
trap stop_handler TERM INT

# Refuse to run on a "main" branch even if the skill missed it.
BRANCH="$(git rev-parse --abbrev-ref HEAD)"
case "$BRANCH" in
  main|master|develop|production)
    echo "[tachikoma] refusing to run on protected branch $BRANCH" >&2
    OUTCOME="error"
    exit 1
    ;;
esac

{
  echo ""
  echo "$RULE_MAIN"
  echo "  $SYM_START starting — repo: $(basename "$REPO") · branch: $BRANCH"
  echo "  cap: $MAX_ITER iter(s) · pid: $$${VERBOSE:+  · mode: dev}"
  echo "$RULE_MAIN"
  echo ""
} | tee "$LOG_FILE"

for ((ITER=1; ITER<=MAX_ITER; ITER++)); do
  echo "$RULE_ITER $ITER / $MAX_ITER ─────────────────────────────────────" | tee -a "$LOG_FILE"

  # Bail if TRACKED files are dirty at iteration start (real corruption).
  # Untracked-only state is a warning — a previous iter may have left a
  # stray lockfile (npm vs pnpm misroute), node_modules junk, or other
  # side-effects that didn't get cleaned up. Those should not nuke a loop
  # whose previous iter committed real work. See runbook:
  # ~/projects/personal-nix/wiki/runbooks/tachikoma-finalize-dirty-tree-bail.md
  DIRTY="$(git status --porcelain)"
  if [ -n "$DIRTY" ]; then
    TRACKED_DIRTY="$(echo "$DIRTY" | grep -v '^??' || true)"
    if [ -n "$TRACKED_DIRTY" ]; then
      echo "[tachikoma] TRACKED files dirty at start of iter $ITER. Bailing — manual cleanup required." | tee -a "$LOG_FILE" >&2
      echo "$TRACKED_DIRTY" | tee -a "$LOG_FILE" >&2
      OUTCOME="error"
      exit 1
    fi
    {
      echo "[tachikoma] WARN — untracked stray files at start of iter $ITER:"
      echo "$DIRTY"
      echo "[tachikoma] continuing iteration; clean these up in your work or add to .gitignore."
    } | tee -a "$LOG_FILE" >&2
  fi

  run_claude "$PROMPT_FILE" "$LOG_FILE"
  RC=$CLAUDE_RC
  RESULT="$(cat "$ITER_TMP" 2>/dev/null || true)"
  rm -f "$ITER_TMP"

  if [ $RC -ne 0 ]; then
    {
      echo ""
      echo "$RULE_MAIN"
      echo "  $SYM_ERR ERROR — claude exited with code $RC at iter $ITER"
      echo "  Run /tachikoma resume to retry, or /tachikoma done to ship what's committed."
      echo "$RULE_MAIN"
      echo ""
    } | tee -a "$LOG_FILE" >&2
    OUTCOME="error"
    exit $RC
  fi

  if [[ "$RESULT" == *"$SENTINEL"* ]]; then
    # ADR 008 P1 — oracle separation. The sentinel is necessary, NOT
    # sufficient. Re-verify independently before shipping. On reject:
    # append the reason to progress.txt and keep iterating.
    VERIFIER_SH="$LIB_DIR/verifier-gate.sh"
    if [ -x "$VERIFIER_SH" ]; then
      {
        echo ""
        echo "$RULE_MAIN"
        echo "  [verifier-gate] sentinel detected — running independent verifier"
        echo "$RULE_MAIN"
      } | tee -a "$LOG_FILE"

      set +e
      GATE_OUT="$(TYPECHECK_CMD="$TYPECHECK_CMD" TEST_CMD="$TEST_CMD" LINT_CMD="$LINT_CMD" \
        "$VERIFIER_SH" "$REPO" "$BASE_BRANCH" 2>>"$LOG_FILE")"
      GATE_RC=$?
      set -e

      if [ $GATE_RC -ne 0 ]; then
        # Gate rejected — record and continue iterating.
        {
          echo ""
          echo "$RULE_MAIN"
          echo "  $SYM_WARN VERIFIER-GATE REJECTED — sentinel emitted but checks failed"
          echo "  Continuing iteration. See progress.txt for details."
          echo "$RULE_MAIN"
          echo ""
        } | tee -a "$LOG_FILE" >&2
        {
          echo ""
          echo "## Iter $ITER — verifier-gate REJECTED (sentinel emitted but harness checks failed)"
          printf '%s\n' "$GATE_OUT"
        } >> "$PROGRESS_FILE"
        # Fall through to milestone block / next iter.
      else
        # Gate passed — proceed to ship.
        {
          echo "  [verifier-gate] PASS"
          echo ""
          echo "$RULE_MAIN"
          echo "  $SYM_DONE TACHIKOMA COMPLETE"
          echo "  $ITER iteration(s) · branch: $(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")"
          echo "$RULE_MAIN"
          echo ""
        } | tee -a "$LOG_FILE"
        OUTCOME="complete"
        VERIFIER_PASSED=1
      fi
    else
      # Legacy path — no verifier installed. Warn and proceed (don't block
      # existing installs that haven't migrated to ADR 008 yet).
      echo "[tachikoma] WARN — verifier-gate.sh not found at $VERIFIER_SH; skipping ADR 008 P1 gate" | tee -a "$LOG_FILE" >&2
      {
        echo ""
        echo "$RULE_MAIN"
        echo "  $SYM_DONE TACHIKOMA COMPLETE"
        echo "  $ITER iteration(s) · branch: $(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")"
        echo "$RULE_MAIN"
        echo ""
      } | tee -a "$LOG_FILE"
      OUTCOME="complete"
      VERIFIER_PASSED=1
    fi

    if [ "${VERIFIER_PASSED:-0}" = "1" ]; then
      if [ -f "$SHIP_PROMPT_FILE" ]; then
        {
          echo ""
          echo "$RULE_SHIP ──────────────────────────────────────────────────"
          echo ""
        } | tee -a "$LOG_FILE"

        SHIP_TOOLS="Bash(git *) Bash(gh *) Bash(osascript *) Bash(cat *) Bash(echo *) Bash(rm *) Bash(mkdir *) Bash(sleep *) Read Write Edit"
        run_claude "$SHIP_PROMPT_FILE" "$LOG_FILE" "$SHIP_TOOLS"
        # also capture to ship log
        cat "$ITER_TMP" 2>/dev/null >> "$SHIP_LOG_FILE" || true
        SHIP_RC=$CLAUDE_RC
        rm -f "$ITER_TMP"

        if [ $SHIP_RC -ne 0 ]; then
          {
            echo ""
            echo "$RULE_MAIN"
            echo "  $SYM_WARN AUTO-SHIP FAILED (exit $SHIP_RC)"
            echo "  Work is committed on branch: $(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')"
            echo "  Run /tachikoma done to ship manually."
            echo "$RULE_MAIN"
            echo ""
          } | tee -a "$LOG_FILE"
        fi
      else
        {
          echo "  [ship] ship.md not found — skipping auto-ship. Run /tachikoma done manually."
          echo ""
        } | tee -a "$LOG_FILE"
      fi

      exit 0
    fi
    # If gate rejected, fall through to milestone-banner block below and loop.
  fi

  LAST_LINE="$(tail -n 1 "$PROGRESS_FILE" 2>/dev/null || true)"
  {
    echo ""
    echo "$RULE_MAIN"
    echo "  $SYM_OK MILESTONE — iter $ITER / $MAX_ITER"
    echo "  ${LAST_LINE:-(progress.txt empty)}"
    echo "$RULE_MAIN"
    echo ""
  } | tee -a "$LOG_FILE"

  # ADR 008 P5 — progress-journal compaction. Every COMPACTION_INTERVAL iters,
  # regenerate progress.summary.md so the next iteration's prompt reads a
  # dense summary + last 3 raw entries instead of an ever-growing journal.
  if [ -n "${COMPACTION_INTERVAL:-}" ] && [ "${COMPACTION_INTERVAL}" != "0" ]; then
    if [ $((ITER % COMPACTION_INTERVAL)) -eq 0 ] && [ -x "$LIB_DIR/progress-summary.sh" ]; then
      echo "  [compact] regenerating progress.summary.md (iter $ITER)" | tee -a "$LOG_FILE"
      set +e
      PLANNER_MODEL="$PLANNER_MODEL" "$LIB_DIR/progress-summary.sh" "$REPO" >> "$LOG_FILE" 2>&1
      set -e
    fi
  fi
done

{
  echo ""
  echo "$RULE_MAIN"
  echo "  $SYM_CAP CAP HIT — $MAX_ITER iterations without sentinel"
  echo "  Run /tachikoma resume to continue, or /tachikoma done to ship what's committed."
  echo "$RULE_MAIN"
  echo ""
} | tee -a "$LOG_FILE"
OUTCOME="cap"
exit 0
